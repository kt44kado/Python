        },
        "required": ["database_name", "table_name"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "execute_select",
      "description": "SELECT実行。SQLにDB名プレフィックスは不要。参照のみ可。",
      "parameters": {
        "type": "object",
        "properties": {
          "database_name": { "type": "string", "description": "実行対象DB名" },
